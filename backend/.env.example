# ── Aplikasi ─────────────────────────────────────────────────────────
APP_NAME="OrderLink API"
APP_ENV=local                  # local | production
APP_KEY=                       # Generate: php artisan key:generate
APP_DEBUG=true                 # false di production (menyembunyikan stack trace)
APP_URL=http://localhost:8000   # Base URL backend

# ── Logging ─────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                # debug | info | warning | error — kurangi di production

# ── Database (MySQL 8.0+) ───────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=orderlink
DB_USERNAME=root
DB_PASSWORD=                   # Sesuaikan dengan password MySQL Anda

# ── Cache & Session ─────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file              # file (dev) | redis (production)
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120           # Menit session bertahan

# ── Sanctum (API Auth) ──────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
SESSION_DOMAIN=localhost

# ── Node.js Realtime Server ─────────────────────────────────────────
REALTIME_SERVER_URL=http://localhost:3001

# ── Frontend URL (for CORS) ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
